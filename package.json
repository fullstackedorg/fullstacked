{
    "version": "1.0.0-alpha",
    "scripts": {
        "build": "node -r @nitrogql/esbuild-register build",
        "start": "node -r @nitrogql/esbuild-register index",
        "fmt": "sh ./fmt.sh",
        "typecheck": "tsc --noEmit",
        "pretest": "npm run build && npm run build -w platform/node",
        "test": "node --experimental-test-coverage --test-coverage-exclude='**/*.js' --test-coverage-exclude='test/**/*' -r @nitrogql/esbuild-register test"
    },
    "workspaces": [
        "platform/electron",
        "platform/node",
        "platform/wasm"
    ],
    "author": "FullStacked",
    "license": "MIT",
    "type": "module",
    "prettier": {
        "tabWidth": 4,
        "trailingComma": "none"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1002.0",
        "@nitrogql/esbuild-register": "^1.7.2",
        "@types/node": "^25.3.3",
        "assert": "^2.1.0",
        "browserify-zlib": "^0.2.0",
        "buffer": "^6.0.3",
        "constants-browserify": "^1.0.0",
        "crypto-browserify": "^3.12.1",
        "csstype": "^3.2.3",
        "dc-polyfill": "^0.1.10",
        "dotenv": "^17.3.1",
        "elliptic": "^6.6.1",
        "esbuild": "^0.27.3",
        "events": "^3.3.0",
        "fast-querystring": "^1.1.2",
        "node-gyp": "^12.2.0",
        "prettier": "^3.8.1",
        "process": "^0.11.10",
        "puppeteer": "^24.39.1",
        "readable-stream": "^4.7.0",
        "string_decoder": "^1.3.0",
        "typescript": "^5.9.3",
        "util": "^0.12.5"
    },
    "overrides": {
        "yauzl": "3.2.1"
    }
}
